{
  "name": "pdsls",
  "license": "0BSD",
  "type": "module",
  "scripts": {
    "start": "bun node_modules/vite/bin/vite.js",
    "predev": "bun scripts/generate-metadata.js",
    "dev": "bun node_modules/vite/bin/vite.js",
    "prebuild": "bun scripts/generate-metadata.js",
    "build": "bun node_modules/vite/bin/vite.js build && bun scripts/build-worker.js",
    "pages:build": "bun install --frozen-lockfile && bun run build",
    "serve": "bun node_modules/vite/bin/vite.js preview",
    "format": "bun node_modules/oxfmt/bin/oxfmt",
    "format:check": "bun node_modules/oxfmt/bin/oxfmt --check",
    "pretypecheck": "bun scripts/generate-metadata.js",
    "typecheck": "bun node_modules/typescript/bin/tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@atcute/atproto": "^4.0.2",
