    "@atcute/identity": "^2.0.0",
    "@atcute/identity-resolver": "^2.0.0",
    "@atcute/lexicon-doc": "^3.0.0",
    "@atcute/lexicon-resolver": "^1.0.0",
    "@atcute/lexicons": "^2.0.0",
    "@atcute/multibase": "^1.2.0",
    "@atcute/oauth-browser-client": "^4.0.0",
