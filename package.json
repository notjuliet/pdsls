    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fsegurai/codemirror-theme-basic-dark": "^6.2.5",
    "@fsegurai/codemirror-theme-basic-light": "^6.2.5",
    "@mary/exif-rm": "https://npm.jsr.io/~/11/@jsr/mary__exif-rm/0.2.2.tgz",
    "@mary/zip": "https://npm.jsr.io/~/11/@jsr/mary__zip/0.2.1.tgz",
    "@skyware/firehose": "^0.5.2",
    "@solidjs/router": "^0.16.1",
    "@takumi-rs/image-response": "^1.6.0",
