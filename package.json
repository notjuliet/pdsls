    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "oxfmt": "^0.53.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12"
  },
  "packageManager": "bun@1.3.14"
